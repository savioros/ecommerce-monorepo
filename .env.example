# =============================================================================
# E-commerce Petshop — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores marcados com <>.
# O .env raiz é lido pelo docker-compose; cada serviço lê também o seu próprio.
# =============================================================================

# -----------------------------------------------------------------------------
# Portas dos serviços
# -----------------------------------------------------------------------------
WEB_PORT=5173
API_PORT=8000
PAYMENTS_PORT=8080

# -----------------------------------------------------------------------------
# web/ — React + Vite
# Variáveis com prefixo VITE_ são expostas ao navegador em tempo de build.
# Copie-as também para web/.env (ou web/.env.local para sobrescrever localmente).
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:8000
VITE_APP_NAME="Petshop"
# Ativar polling de filesystem no Vite quando o driver de volume do Docker
# não propagar eventos inotify (ex.: Docker Desktop com gRPC FUSE no macOS).
# Deixar vazio (padrão) para Docker Desktop com VirtioFS ou uso sem Docker.
# VITE_WATCH_POLL=1

# -----------------------------------------------------------------------------
# api/ — Laravel
# -----------------------------------------------------------------------------
APP_NAME="Petshop API"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

# Banco de dados — Laravel lê estas variáveis; em Docker são injetadas pelo compose.
# Para dev local sem Docker, aponte DB_HOST para 127.0.0.1.
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=petshop
DB_USERNAME=petshop
DB_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database
CACHE_STORE=database
FILESYSTEM_DISK=local
BROADCAST_CONNECTION=log

MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS="noreply@petshop.local"
MAIL_FROM_NAME="${APP_NAME}"

# PostgreSQL — configuração do serviço do docker-compose
POSTGRES_PORT=5432
POSTGRES_DB=petshop
POSTGRES_USER=petshop
POSTGRES_PASSWORD=secret

# URL do microsserviço de pagamentos (payments/)
PAYMENTS_SERVICE_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# payments/ — Spring Boot (Fase 2 — serviço ainda não implementado)
# -----------------------------------------------------------------------------
SPRING_APPLICATION_NAME=payments-service
SPRING_SERVER_PORT=8080
# H2 in-memory para desenvolvimento; trocar por PostgreSQL na Fase 2.
# SPRING_DATASOURCE_URL=jdbc:h2:mem:paymentsdb
# SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.h2.Driver
# SPRING_DATASOURCE_USERNAME=sa
# SPRING_DATASOURCE_PASSWORD=
